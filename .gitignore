# Root-level gitignore for LivePop monorepo

# Dependencies
node_modules/

# Build output
dist/
build/

# Environment files (keep examples, ignore actuals)
.env
.env.local
.env.*.local
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/

# Coverage reports
coverage/

# TypeScript build info
*.tsbuildinfo

# Antigravity / Gemini AI files
.gemini/
